<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>NeuraPulse Logo</title>
<style>
  body {
    background: #020617;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
  }

  .logo-box {
    position: relative;
    width: 200px;
    height: 200px;
    border-radius: 30px;
    border: 4px solid #22d3ee;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 0 20px #22d3ee;
  }

  .logo-text {
    font-size: 100px;
    color: #cbd5f5;
    font-weight: bold;
    font-family: Arial, sans-serif;
  }

  .plus {
    position: absolute;
    top: 15px;
    right: 15px;
    font-size: 40px;
    color: #22d3ee;
    font-weight: bold;
  }

  .bottom-line {
    position: absolute;
    bottom: -15px;
    left: 10px;
    width: 80%;
    height: 6px;
    border-radius: 10px;
    background: linear-gradient(to right, #7c3aed, #22d3ee);
  }
</style>
</head>
<body>

<div class="logo-box">
  <div class="logo-text">N</div>
  <div class="plus">+</div>
  <div class="bottom-line"></div>
</div>

</body>
</html>
